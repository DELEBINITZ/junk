# --- Qdrant (the SAME instance the platform reads from) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# MUST equal the app's USER_GUIDE_COLLECTION (settings.user_guide_collection).
USER_GUIDE_COLLECTION=user_guide_kb

# --- Embeddings (the SAME TEI server + dim the app queries with) ---
# The app embeds queries here; this service must embed passages on the same server
# and dimension, or query/passage vectors won't match.
TEI_EMBED_URL=http://localhost:8080
EMBEDDING_DIM=2560

# --- Provenance / tagging (stored on every point) ---
GUIDE_SOURCE=fortirecon_user_guide
GUIDE_PRODUCT=FortiRecon
GUIDE_VERSION=26.2.a

# --- Ingestion behavior ---
# 1 = delete a page's prior chunks before re-indexing (use when a page shrank).
REINDEX_DELETE_FIRST=0
CHUNK_MAX_WORDS=350
CHUNK_OVERLAP=50
EMBED_BATCH=32
EMBED_TIMEOUT=60
# Crawl politeness (seconds between requests) + per-request fetch timeout.
CRAWL_DELAY=0.5
FETCH_TIMEOUT=30
