"""Tools for the <FEATURE> module.

Each tool: typed args, a docstring the LLM reads to decide use, structured
returns, errors-as-data. Mark side-effecting tools (they route through the
human-approval gate automatically). Pull core services from ``ctx.deps`` — never
global state — so tools stay tenant-safe and unit-testable.
"""

from __future__ import annotations

from pydantic import BaseModel, Field

from app.core.contracts import Citation, ToolContext, ToolError, ToolResult, tool


class ExampleArgs(BaseModel):
    query: str = Field(default="", description="What to look up.")


@tool(name="<feature>_lookup",
      description="<what this returns and when the agent should call it>",
      args_schema=ExampleArgs, rbac_role="viewer")
async def lookup(args: ExampleArgs, ctx: ToolContext):
    # ctx.org_id is the trusted tenant; ctx.deps.rag / ctx.deps.llm are available.
    rows: list[dict] = []  # TODO: query your backend, scoped to ctx.org_id
    cites = [Citation(doc_id=str(i), source="<feature>", snippet=str(r)) for i, r in enumerate(rows)]
    return ToolResult(data={"results": rows, "count": len(rows)}, citations=cites)


# Example side-effecting tool (gated; only runs after human approval):
# @tool(name="<feature>_action", description="...", args_schema=..., side_effecting=True,
#       rbac_role="analyst", autonomy=Autonomy.SUGGEST)
# async def do_action(args, ctx): ...


TOOLS = (lookup,)

__all__ = ["TOOLS", "lookup"]
