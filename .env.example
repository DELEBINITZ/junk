# ---------------------------------------------------------------------------
# Agentic Security Intelligence — DEV / local environment template
# Copy to `.env` and fill in. NOTE: the offline/deterministic stubs were removed —
# the platform needs REAL infra to boot: an LLM (SGLang or any OpenAI-compatible
# endpoint), an embedder (TEI or OpenAI), Qdrant, and Postgres. The quickest local
# setup is OpenAI for LLM+embeddings (just an API key) + local Qdrant + local Postgres.
#
# AUTH MODEL (one mechanism): every request carries (1) a gateway API KEY in the
# `X-API-Key` header AND (2) a JWT (Authorization: Bearer ...) whose claims carry the
# identity (org_id / sub / roles). The JWT is minted upstream; this service verifies it.
#
# FOR PRODUCTION: use `.env.production`. With ENVIRONMENT=prod the app fail-closes at
# boot on insecure/incomplete config (see config.py::_enforce_prod_no_stub).
# ---------------------------------------------------------------------------

# ---- App ----
ENVIRONMENT=dev                 # dev | staging | prod
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*                  # comma-separated or JSON list

# ---- Auth (API key gates the request; JWT carries identity) ----
# API_KEYS: the accepted gateway keys (X-API-Key header, or ?api_key= for SSE).
API_KEYS=dev-api-key-change-me  # comma-separated or JSON list; CHANGE in prod
# JWT: verified per request; the secret signs/verifies it (HS256). Mint dev tokens
# with create_access_token(settings, sub=..., org_id=..., roles=(...)) — see jwt.py.
JWT_SECRET=dev-insecure-change-me-please-32byte-minimum-secret   # CHANGE in prod (32+ bytes)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600

# ---- Stores (Postgres is the only chat/session store) ----
STORE_BACKEND=postgres          # postgres (only option — required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asi   # REQUIRED
RLS_SETTING_NAME=app.organization_id
CACHE_BACKEND=memory            # memory | redis (optional response cache)
REDIS_URL=
SEMANTIC_CACHE_ENABLED=false

# ---- LLM (required — no offline stub) ----
LLM_PROVIDER=sglang             # sglang | openai
# SGLang (self-hosted, OpenAI-compatible) — three model lanes
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_API_KEY=EMPTY
MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
MODEL_STANDARD=Qwen/Qwen2.5-72B-Instruct
MODEL_DEEP=deepseek-ai/DeepSeek-V3.1
# OpenAI-compatible provider (LLM_PROVIDER=openai) — easiest local dev (no GPU)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ---- Embeddings (required — no offline stub) ----
EMBEDDING_PROVIDER=tei          # tei | openai
TEI_EMBED_URL=http://localhost:8080
EMBEDDING_DIM=1024
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# ---- Retrieval (Qdrant is the only vector backend) ----
RETRIEVAL_BACKEND=qdrant        # qdrant (only option — required)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RETRIEVAL_TOP_K=20
RERANK_ENABLED=false
RERANK_PROVIDER=none            # none | tei
TEI_RERANK_URL=http://localhost:8081
RERANK_TOP_K=6

# ---- Guardrails ----
GUARDRAILS_ENABLED=true
PII_REDACTION=true
INJECTION_DETECTION=true
TOPIC_SAFETY=true
GROUNDEDNESS_CHECK=true
PROMPT_GUARD_URL=
LLAMA_GUARD_URL=

# ---- Agent (dynamic routing + deep-reasoning planner are ON by default) ----
AGENT_ENGINE=internal           # internal | langgraph
ROUTER_MODE=llm                 # llm (LLM picks modules) | heuristic
ROUTING_STRATEGY=semantic       # semantic (embedding fallback when not using the LLM router)
ORCHESTRATOR_MODE=planner       # planner (plan -> dispatch -> reflect) | heuristic
MAX_TOOL_ITERATIONS=4
MAX_PLAN_STEPS=6
MAX_REPLANS=2                   # deep-reasoning reflect loop depth (LLM mode)
PLANNER_MAX_FANOUT=2

# ---- MCP (remote tool servers) ----
# Promote ANY capability module to its own MCP server with ZERO code edits: add its
# id -> url here. A new MCP-backed module = write its manifest + one entry below.
MCP_URLS=                       # JSON: {"easm":"http://easm-mcp:8000/mcp","newmod":"http://..."}
# Legacy per-module fields (still honored; MCP_URLS wins if both set):
EASM_MCP_URL=
BRAND_MCP_URL=
ACI_MCP_URL=
TESTKIT_MCP_URL=                # e.g. http://localhost:3000/mcp (the mcp-test-kits server)
MCP_SERVICE_TOKEN_TTL_SECONDS=120
MAX_TOOLS_ADVERTISED=8

# ---- Observability (recommend turning tracing ON to see the reasoning loop) ----
TRACING_PROVIDER=none           # none | langfuse
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
METRICS_ENABLED=true

# ---- Capabilities (which modules load in this deployment) ----
CAP_REPORTS_ENABLED=true
CAP_EASM_ENABLED=true
CAP_BRAND_ENABLED=false
CAP_ACI_ENABLED=false
CAP_TESTKIT_ENABLED=true

# ---- Concurrency / fairness ----
MAX_CONCURRENT_GENERATIONS=32
PER_ORG_CONCURRENCY=8
REQUEST_TIMEOUT_SECONDS=120
QUEUE_MAX_SIZE=256
