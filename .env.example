# ---------------------------------------------------------------------------
# Agentic Security Intelligence — environment template
# Copy to `.env`. EVERY value below has a safe default; with NONE set the system
# runs fully on the zero-infra deterministic path (no GPU, no keys, no network).
# Flip a provider + add creds to switch on the real production backend.
# ---------------------------------------------------------------------------

# ---- App ----
ENVIRONMENT=dev                 # dev | staging | prod
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*                  # comma-separated or JSON list

# ---- Auth ----
AUTH_PROVIDER=local             # local | oidc
JWT_SECRET=dev-insecure-change-me-please-32byte-minimum-secret   # CHANGE in prod (32+ bytes)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=1209600
# OIDC (AUTH_PROVIDER=oidc)
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ORG_CLAIM=org_id
OIDC_ROLES_CLAIM=roles

# ---- Stores ----
STORE_BACKEND=memory            # memory | postgres
DATABASE_URL=                   # postgresql://user:pass@host:5432/asi
RLS_SETTING_NAME=app.organization_id
CACHE_BACKEND=memory            # memory | redis
REDIS_URL=
SEMANTIC_CACHE_ENABLED=false

# ---- LLM ----
LLM_PROVIDER=deterministic      # deterministic | sglang | openai
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_API_KEY=EMPTY
MODEL_FAST=Qwen/Qwen2.5-7B-Instruct
MODEL_STANDARD=Qwen/Qwen2.5-72B-Instruct
MODEL_DEEP=deepseek-ai/DeepSeek-V3.1
# OpenAI-compatible dev provider (LLM_PROVIDER=openai) — NOT for sensitive prod data
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ---- Embeddings ----
EMBEDDING_PROVIDER=deterministic   # deterministic | tei | openai
TEI_EMBED_URL=http://localhost:8080
EMBEDDING_DIM=1024
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# ---- Retrieval ----
RETRIEVAL_BACKEND=memory        # memory | qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RETRIEVAL_TOP_K=20
RERANK_ENABLED=false
RERANK_PROVIDER=none            # none | tei
TEI_RERANK_URL=http://localhost:8081
RERANK_TOP_K=6

# ---- Guardrails ----
GUARDRAILS_ENABLED=true
PII_REDACTION=true
INJECTION_DETECTION=true
TOPIC_SAFETY=true
GROUNDEDNESS_CHECK=true
PROMPT_GUARD_URL=
LLAMA_GUARD_URL=

# ---- Agent ----
AGENT_ENGINE=internal           # internal | langgraph
MAX_TOOL_ITERATIONS=4
ROUTER_MODE=heuristic           # heuristic | llm

# ---- Observability ----
TRACING_PROVIDER=none           # none | langfuse
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
METRICS_ENABLED=true

# ---- Capabilities (which modules load in this deployment) ----
CAP_REPORTS_ENABLED=true
CAP_EASM_ENABLED=true
CAP_BRAND_ENABLED=false
CAP_ACI_ENABLED=false

# ---- Concurrency / fairness ----
MAX_CONCURRENT_GENERATIONS=32
PER_ORG_CONCURRENCY=8
REQUEST_TIMEOUT_SECONDS=120
QUEUE_MAX_SIZE=256
