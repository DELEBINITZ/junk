# ---- App ----
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ---- Assistant identity + capability gating ----
# The assistant's personality/scope is DERIVED from whichever agents are enabled.
# ENABLED_AGENTS: comma-separated allowlist of agent ids to activate. Blank = every
#   agent that is otherwise available. e.g. bring the security agents online later:
#   ENABLED_AGENTS=reports,easm,userguide   (or blank to enable everything available)
# CURRENT SHIP CONFIG: user-guide agent ONLY, presented as "Atlas".
ENABLED_AGENTS=userguide
# ASSISTANT_NAME / ASSISTANT_TAGLINE: optional overrides. Blank = auto-derive from the
# enabled agents (e.g. userguide-only -> "FortiRecon User Guide Assistant").
ASSISTANT_NAME=Atlas
ASSISTANT_TAGLINE=your friendly FortiRecon assistant

# ---- Auth ----
API_KEYS=dev-api-key-change-me
JWT_SECRET=dev-insecure-change-me-please-32byte-minimum-secret
JWT_ALGORITHM=HS256

# ---- LLM (ChatOpenAI → vLLM/SGLang) ----
LLM_BASE_URL=http://localhost:30000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_FAST_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_DEEP_MODEL=deepseek-ai/DeepSeek-V3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ---- Chat Context ----
HISTORY_WINDOW_MESSAGES=20

# ---- Embeddings ----
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=reports_kb
# Product user-guide / documentation corpus (ingested by services/userguide-ingest).
# The User Guide agent registers only when this collection is non-empty.
USER_GUIDE_COLLECTION=user_guide_kb

# ---- PostgreSQL (chat persistence + checkpointing + RLS) ----
DATABASE_URL=postgresql://asi:asi@localhost:5432/asi

# ---- MCP Servers (JSON — add a NEW agent with NO code changes) ----
# Each server here is auto-registered as an agent: its tools are discovered from the
# server, its identity from the optional display_name/description/capabilities (else
# derived from the tool names). The router/planner/persona pick it up automatically.
# Format:
#   {"agent_id": {"url": "https://…/mcp", "transport": "streamable_http", "api_key": "…",
#                 "display_name": "Brand Protection Agent",
#                 "description": "Monitors brand abuse, phishing, typosquatting.",
#                 "capabilities": ["Detect impersonation", "Track phishing domains"],
#                 "side_effecting_tools": ["takedown_request"]}}
MCP_SERVERS={}

# ---- EASM MCP Server (dedicated shortcut) ----
EASM_MCP_URL=
EASM_MCP_API_KEY=
EASM_MCP_TRANSPORT=streamable_http   # streamable_http | sse

# ---- Security ----
GUARDRAILS_ENABLED=true
PII_REDACTION=true
HUMAN_APPROVAL_REQUIRED=true

# ---- Observability: Langfuse (recommended) ----
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Observability: LangSmith (alternative) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=security-intel

# ---- CORS ----
CORS_ORIGINS=*
