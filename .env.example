APP_NAME="Enterprise Contract Intelligence PoC"
JWT_SECRET="demo-local-secret-change-before-prod"
JWT_ISSUER="contract-intelligence-poc"
ACCESS_TOKEN_MINUTES=120
CONTRACT_CORPUS_DIR="Assignment_org"
EMBEDDING_DIMENSIONS=384
EMBEDDING_PROVIDER="hash"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
LLM_PROVIDER="deterministic"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b-instruct"
VLLM_BASE_URL="http://localhost:8001/v1"
VLLM_MODEL="Qwen/Qwen2.5-7B-Instruct"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
DATABASE_URL="postgresql://contract_user:contract_pass@localhost:5432/contract_intelligence"

# --- Production backbone (all default to the local/in-memory path) ---
# Durable storage: "memory" (default) | "postgres" (RLS-backed chat persistence).
# Postgres + Qdrant backends require the `prod` extra installed in the image.
STORE_BACKEND="memory"
RLS_SETTING_NAME="app.organization_id"
# Retrieval: "memory" (default in-process) | "qdrant" (hybrid + mandatory org filter).
RETRIEVAL_BACKEND="memory"
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="reports_kb"
# Embeddings: EMBEDDING_PROVIDER=tei to use Text-Embeddings-Inference.
TEI_BASE_URL="http://localhost:8080"
TEI_MODEL="Qwen/Qwen3-Embedding-8B"
# Inference lanes: set LLM_PROVIDER=sglang to use the self-hosted answerer.
SGLANG_BASE_URL="http://localhost:30000/v1"
SGLANG_MODEL_STANDARD="Qwen/Qwen2.5-72B-Instruct"
SGLANG_MODEL_FAST="Qwen/Qwen2.5-7B-Instruct"
SGLANG_MODEL_DEEP="deepseek-ai/DeepSeek-V3.1"
# Guardrails topic/safety classifier: "off" (default) | "llama_guard".
TOPIC_SAFETY_PROVIDER="off"
