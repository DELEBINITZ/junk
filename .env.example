# ---------------------------------------------------------------------------
# Agentic Security Intelligence — environment template (copy to `.env`)
#
# ONLY the values you must actually set live here: secrets, creds, and the URLs
# of your infra. EVERYTHING ELSE has a sensible default in app/config.py — to
# override any of those, just add its UPPER_CASE name here (full list +
# production setup in PRODUCTION_SETUP.txt).
#
# Auth: every request needs an API key (X-API-Key, in API_KEYS) AND a JWT
# (Authorization: Bearer ...) whose claims carry org_id/sub/roles. The JWT is
# minted upstream; this service verifies it with JWT_SECRET.
#
# Real infra is required (no offline stubs). Quickest local start: LLM_PROVIDER=openai
# + EMBEDDING_PROVIDER=openai (just OPENAI_API_KEY) + local Qdrant + local Postgres.
# ---------------------------------------------------------------------------

ENVIRONMENT=dev                  # dev | prod   (prod boot-guards the secrets/infra below)

# ---- Secrets (CHANGE for prod; pull from your secret manager) ----
API_KEYS=dev-api-key-change-me                                   # gateway key(s); CSV or JSON
JWT_SECRET=dev-insecure-change-me-please-32byte-minimum-secret   # 32+ bytes in prod
CORS_ORIGINS=*                   # restrict to your front-end origin(s) in prod

# ---- Datastores ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asi   # Postgres (run `asi-migrate`)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=                       # optional; set + CACHE_BACKEND=redis for a shared cache

# ---- LLM (pick one provider) ----
LLM_PROVIDER=sglang              # sglang | vllm | openai
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_API_KEY=EMPTY
VLLM_BASE_URL=http://localhost:8000/v1   # for LLM_PROVIDER=vllm (e.g. a 32B for staging)
VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct     # all lanes map to this single served model
OPENAI_API_KEY=                  # set this (and LLM_PROVIDER/EMBEDDING_PROVIDER=openai) for no-GPU dev

# ---- Embeddings ----
EMBEDDING_PROVIDER=tei           # tei | openai
TEI_EMBED_URL=http://localhost:8080
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560               # 4B native; MUST equal the Qdrant collection dim + the ingestion cron

# ---- Guardrails ----
# Nothing to set: injection + content safety run on the main LLM (LLMJudgeGuard).
# PII = Microsoft Presidio, installed via the `pii` extra (+ spaCy model).
# Toggles (default true): INJECTION_DETECTION / TOPIC_SAFETY / PII_REDACTION /
# GUARDRAILS_FAIL_CLOSED.

# ---- Remote MCP capability servers (optional; zero code edit) ----
MCP_URLS=                        # JSON {module_id: url}, e.g. {"easm":"http://easm-mcp:8000/mcp"}
# Transport auth for remote MCP (required in prod when a server is wired): the
# X-API-Key the client sends and the server checks. One shared key or per-server map.
MCP_API_KEY=                     # e.g. a strong shared key; set the SAME on each server
# MCP_API_KEYS=                  # JSON {module_id: key} for per-server keys (preferred)
# Optional identity hardening (asymmetric service token; core=private, server=public):
# JWT_SERVICE_PRIVATE_KEY=       # PEM (core only)   JWT_SERVICE_PUBLIC_KEY=  # PEM (server only)

# ---- Observability (optional; recommend langfuse in prod) ----
TRACING_PROVIDER=none            # none | langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Capability modules live in this deployment ----
CAP_REPORTS_ENABLED=true
CAP_EASM_ENABLED=true
CAP_BRAND_ENABLED=false
CAP_ACI_ENABLED=false
CAP_TESTKIT_ENABLED=false        # the mcp-test-kits demo module; keep off in prod
